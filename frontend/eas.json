{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://family-guard-37.preview.emergentagent.com",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "AIzaSyBeIZ4yanf7KrSzOaGpGoqsoBWbnyBsc_I"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://kinnectcare-production.up.railway.app",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "AIzaSyBeIZ4yanf7KrSzOaGpGoqsoBWbnyBsc_I"
      }
    },
    "production": {
      "channel": "production",
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://kinnectcare-production.up.railway.app",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "AIzaSyBeIZ4yanf7KrSzOaGpGoqsoBWbnyBsc_I"
      }
    },
    "production-apk": {
      "extends": "production",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "REPLACE_WITH_YOUR_APPLE_ID@example.com",
        "ascAppId": "REPLACE_WITH_10_DIGIT_APP_STORE_CONNECT_ID",
        "appleTeamId": "REPLACE_WITH_10_CHAR_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
