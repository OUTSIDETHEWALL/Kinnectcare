# .easignore — controls what files are uploaded to EAS Build cloud.
# Defaults to .gitignore if this file is absent. We override here so the
# Firebase config (google-services.json) IS uploaded — it's intentionally
# gitignored to keep the project_number/api_key out of public source control,
# but EAS needs it to compile the Android binary with FCM support.
#
# Mirror of .gitignore EXCEPT we remove google-services.json from the ignore
# list.

# OSX
#
.DS_Store

# Xcode
#
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata
*.xccheckout
*.moved-aside
DerivedData
*.hmap
*.ipa
*.xcuserstate

# Android/IntelliJ
#
build/
.idea
.gradle
local.properties
*.iml
*.hprof
.cxx/
*.keystore
!debug.keystore

# node.js
#
node_modules/
npm-debug.log
yarn-error.log

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# EAS / Play store secrets (these we DO keep out — service-account JSONs
# are server credentials, not client config like google-services.json).
play-service-account*.json
AuthKey_*.p8
*.appstoreconnect.json

# NOTE: google-services.json is intentionally NOT listed here. It IS
# listed in .gitignore (to keep it out of GitHub) but EAS Build needs it
# to compile Android with FCM. EAS reads .easignore first if present.
